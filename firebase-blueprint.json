{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and presence.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "displayName", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between two or more users.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["dm", "group"] },
        "participants": { "type": "array", "items": { "type": "string" } },
        "name": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "lastRead": { "type": "object", "description": "Map of user UIDs to their last read timestamp." },
        "typing": { "type": "object", "description": "Map of user UIDs to their typing status timestamp." }
      },
      "required": ["type", "participants", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a chat.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "UserProfile", "description": "User profiles" },
    "/usernames/{username}": { "schema": { "type": "object", "properties": { "uid": { "type": "string" } } }, "description": "Username uniqueness mapping" },
    "/chats/{chatId}": { "schema": "Chat", "description": "Chat conversations" },
    "/chats/{chatId}/messages/{messageId}": { "schema": "Message", "description": "Messages within a chat" }
  }
}
