// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: uid (string)
// Fields:
//   - uid: string (required)
//   - username: string (required) - Unique lowercase username
//   - displayName: string (required)
//   - photoURL: string (optional)
//   - email: string (optional)
//   - createdAt: timestamp (required)
//
// Collection: usernames
// Document ID: username (string)
// Fields:
//   - uid: string (required)
//
// Collection: chats
// Document ID: chatId (string)
// Fields:
//   - type: string (required) - "dm" or "group"
//   - participants: list (required) - List of user UIDs
//   - name: string (optional) - Group name
//   - lastMessage: string (optional)
//   - updatedAt: timestamp (required)
//   - createdBy: string (optional)
//
// Subcollection: messages (under chats/{chatId})
// Document ID: messageId (string)
// Fields:
//   - text: string (required)
//   - senderId: string (required)
//   - senderName: string (optional)
//   - timestamp: timestamp (required)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isParticipant(chatId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function isChatCreator(chatId) {
      return isAuthenticated() && get(/databases/$(database)/documents/chats/$(chatId)).data.createdBy == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profiles
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && 
                      request.resource.data.uid == uid &&
                      request.resource.data.username is string &&
                      request.resource.data.username.size() >= 3 &&
                      request.resource.data.username.size() <= 20 &&
                      request.resource.data.displayName is string &&
                      request.resource.data.displayName.size() <= 50;
      allow update: if isOwner(uid) && 
                      request.resource.data.uid == uid &&
                      request.resource.data.username == resource.data.username &&
                      (!('displayName' in request.resource.data) || (request.resource.data.displayName is string && request.resource.data.displayName.size() <= 50)) &&
                      (!('photoURL' in request.resource.data) || (request.resource.data.photoURL is string && request.resource.data.photoURL.size() <= 500));
    }

    // Username Uniqueness Check
    match /usernames/{username} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    // Chats
    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants &&
                      (!('name' in request.resource.data) || (request.resource.data.name is string && request.resource.data.name.size() <= 50));
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants && (
        // Allow updating lastMessage, updatedAt, lastRead, and typing
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'updatedAt', 'lastRead', 'typing', 'participants', 'name']) &&
        // Validate lastMessage size if present
        (!('lastMessage' in request.resource.data) || (request.resource.data.lastMessage is string && request.resource.data.lastMessage.size() <= 1000)) &&
        // Validate name size if present
        (!('name' in request.resource.data) || (request.resource.data.name is string && request.resource.data.name.size() <= 50)) &&
        // If updating participants or name, must be the creator
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['participants', 'name']) || resource.data.createdBy == request.auth.uid)
      );
      allow delete: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || (resource.data.type == 'dm' && request.auth.uid in resource.data.participants));

      // Messages
      match /messages/{messageId} {
        allow read: if isParticipant(chatId);
        allow create: if isParticipant(chatId) && 
                        request.resource.data.senderId == request.auth.uid &&
                        request.resource.data.text is string &&
                        request.resource.data.text.size() <= 2000;
        allow update: if isParticipant(chatId) && resource.data.senderId == request.auth.uid &&
                        request.resource.data.text is string &&
                        request.resource.data.text.size() <= 2000;
        allow delete: if isParticipant(chatId) && (resource.data.senderId == request.auth.uid || isChatCreator(chatId));
      }
    }
  }
}
