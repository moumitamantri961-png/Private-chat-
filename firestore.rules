// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: rooms
// Document ID: roomId (string)
// Fields:
//   - name: string (required) - Unique room name
//   - passwordHash: string (required) - SHA-256 hashed password
//   - users: list (optional) - List of guest user IDs
//   - finishStatus: map (optional) - Map of guest ID to boolean status
//   - lastActivity: timestamp (required) - Last activity timestamp
//   - typing: map (optional) - Map of guest ID to boolean typing status
//
// Subcollection: messages (under rooms/{roomId})
// Document ID: messageId (string)
// Fields:
//   - text: string (required) - Message content
//   - timestamp: timestamp (required) - Message timestamp
//   - userId: string (required) - Guest's user ID
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // In Guest Mode, we don't rely on request.auth
    // Instead, we validate the structure and ownership via data fields

    function isValidRoom(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.passwordHash is string && data.passwordHash.size() == 64 &&
             data.lastActivity is timestamp;
    }

    function isValidMessage(data) {
      return data.text is string && data.text.size() > 0 && data.text.size() < 2000 &&
             data.timestamp is timestamp &&
             data.userId is string && data.userId.size() > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /rooms/{roomId} {
      // Allow read for everyone (protected by room ID knowledge + password in app)
      allow read: if true;
      
      // Allow create if room doesn't exist and data is valid
      allow create: if !exists(/databases/$(database)/documents/rooms/$(roomId)) &&
                      isValidRoom(request.resource.data) &&
                      request.resource.data.name == roomId;
      
      // Allow update if data is valid
      allow update: if isValidRoom(request.resource.data);
      
      // Allow delete (for the "Finish Chat" logic)
      allow delete: if true;

      match /messages/{messageId} {
        // Allow read
        allow read: if true;
        
        // Allow create if message is valid
        allow create: if isValidMessage(request.resource.data);
      }
    }
  }
}
